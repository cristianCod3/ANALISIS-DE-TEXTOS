    barra = ttk.Progressbar(frame, length=300, mode='determinate', variable=variable, style=f"{texto}.Horizontal.TProgressbar")
    barra.grid(row=fila, column=1, padx=10, pady=6)
    
    lbl_val = tk.Label(frame, text="0.00%", font=("Arial", 10), bg="#252538", fg="#a0a0b0", width=8, anchor="e")
