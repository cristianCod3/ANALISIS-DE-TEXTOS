raices_raiz_musica1 = [stemmer.stem(i) for i in raiz_musica1_limpio if len(i) > 3 and i not in palabras_vacias]
raiz_musica1_final = set(raices_raiz_musica1)

raiz_musica2_limpio = raiz_musica2.replace(".", "").replace(",", "").lower().split()
raices_raiz_musica2 = [stemmer.stem(i) for i in raiz_musica2_limpio if len(i) > 3 and i not in palabras_vacias]
raiz_musica2_final = set(raices_raiz_musica2)

raiz_musica3_limpio = raiz_musica3.replace(".", "").replace(",", "").lower().split()
raices_raiz_musica3 = [stemmer.stem(i) for i in raiz_musica3_limpio if len(i) > 3 and i not in palabras_vacias]
raiz_musica3_final = set(raices_raiz_musica3)



# 3. CÁLCULO DE FRECUENCIAS DE TÉRMINO (TF)
# es uno de los terminos que nos ayudará a saber el valor de cada palabra, se basa en saber la frecuencia con la que cada palabra aparece en un tipo de texto u otro

#  Programación 
frecuencias_tfRPF1 = {i: raices_raiz_programacion1.count(i) / len(raices_raiz_programacion1) for i in raiz_programacion1_final}
frecuencias_tfRPF2 = {i: raices_raiz_programacion2.count(i) / len(raices_raiz_programacion2) for i in raiz_programacion2_final}
frecuencias_tfRPF3 = {i: raices_raiz_programacion3.count(i) / len(raices_raiz_programacion3) for i in raiz_programacion3_final}

#  Coches 
frecuencias_tfRCF1 = {i: raices_raiz_coches1.count(i) / len(raices_raiz_coches1) for i in raiz_coches1_final}
frecuencias_tfRCF2 = {i: raices_raiz_coches2.count(i) / len(raices_raiz_coches2) for i in raiz_coches2_final}
frecuencias_tfRCF3 = {i: raices_raiz_coches3.count(i) / len(raices_raiz_coches3) for i in raiz_coches3_final}

#  Ajedrez 
frecuencias_tfRAF1 = {i: raices_raiz_ajedrez1.count(i) / len(raices_raiz_ajedrez1) for i in raiz_ajedrez1_final}
frecuencias_tfRAF2 = {i: raices_raiz_ajedrez2.count(i) / len(raices_raiz_ajedrez2) for i in raiz_ajedrez2_final}
frecuencias_tfRAF3 = {i: raices_raiz_ajedrez3.count(i) / len(raices_raiz_ajedrez3) for i in raiz_ajedrez3_final}

#  Música 
frecuencias_tfRMF1 = {i: raices_raiz_musica1.count(i) / len(raices_raiz_musica1) for i in raiz_musica1_final}
frecuencias_tfRMF2 = {i: raices_raiz_musica2.count(i) / len(raices_raiz_musica2) for i in raiz_musica2_final}
frecuencias_tfRMF3 = {i: raices_raiz_musica3.count(i) / len(raices_raiz_musica3) for i in raiz_musica3_final}



# 4. VOCABULARIO GLOBAL E IDF (FRECUENCIA INVERSA DE DOCUMENTO)
# ahora calculamos el IDF, tambien sirve para saber la importancia de cada palabra, mide en cuantos textos distintos aparece cada palabra

# Unimos el vocabulario único de absolutamente todos los textos semilla
vocabulario_global = (
    raiz_programacion1_final | raiz_programacion2_final | raiz_programacion3_final |
    raiz_coches1_final | raiz_coches2_final | raiz_coches3_final |
    raiz_ajedrez1_final | raiz_ajedrez2_final | raiz_ajedrez3_final |
    raiz_musica1_final | raiz_musica2_final | raiz_musica3_final
)

todos_los_documentos = [
    raiz_programacion1_final, raiz_programacion2_final, raiz_programacion3_final,
    raiz_coches1_final, raiz_coches2_final, raiz_coches3_final,
    raiz_ajedrez1_final, raiz_ajedrez2_final, raiz_ajedrez3_final,
    raiz_musica1_final, raiz_musica2_final, raiz_musica3_final
]
total_documentos = len(todos_los_documentos)  # 12 documentos en total

valores_idf = {}
for palabra in vocabulario_global:
    documentos_con_la_palabra = 0
    for doc in todos_los_documentos:
        if palabra in doc:
            documentos_con_la_palabra += 1
            
    valores_idf[palabra] = math.log(total_documentos / documentos_con_la_palabra) + 1



# 5. CREACIÓN DE LOS VECTORES TF-IDF SEMILLA
# ahora que tenemos tanto el TF como el IDF, calculamos el valor de cada palabra
lista_vocabulario = list(vocabulario_global)

# Vectores numéricos finales para cada texto
v_prog1, v_prog2, v_prog3 = [], [], []
v_coch1, v_coch2, v_coch3 = [], [], []
v_ajed1, v_ajed2, v_ajed3 = [], [], []
v_musi1, v_musi2, v_musi3 = [], [], []

for palabra in lista_vocabulario:
    idf = valores_idf.get(palabra, 0)
    
    # Programación
    v_prog1.append(frecuencias_tfRPF1.get(palabra, 0) * idf)
    v_prog2.append(frecuencias_tfRPF2.get(palabra, 0) * idf)
    v_prog3.append(frecuencias_tfRPF3.get(palabra, 0) * idf)
    
    # Coches
    v_coch1.append(frecuencias_tfRCF1.get(palabra, 0) * idf)
    v_coch2.append(frecuencias_tfRCF2.get(palabra, 0) * idf)
    v_coch3.append(frecuencias_tfRCF3.get(palabra, 0) * idf)
    
    # Ajedrez
    v_ajed1.append(frecuencias_tfRAF1.get(palabra, 0) * idf)
    v_ajed2.append(frecuencias_tfRAF2.get(palabra, 0) * idf)
    v_ajed3.append(frecuencias_tfRAF3.get(palabra, 0) * idf)
    
    # Música
    v_musi1.append(frecuencias_tfRMF1.get(palabra, 0) * idf)
    v_musi2.append(frecuencias_tfRMF2.get(palabra, 0) * idf)
    v_musi3.append(frecuencias_tfRMF3.get(palabra, 0) * idf)



# 6. FUNCIÓN MATEMÁTICA DE SIMILITUD
# mide que tan parecido es el texto a analizar respecto a los datos de los textos semilla
def calcular_similitud_coseno(vector_a, vector_b):
    producto_escalar = sum(a * b for a, b in zip(vector_a, vector_b))
    norma_a = math.sqrt(sum(a**2 for a in vector_a))
    norma_b = math.sqrt(sum(b**2 for b in vector_b))
    
    if norma_a == 0 or norma_b == 0:
        return 0.0
        
    return producto_escalar / (norma_a * norma_b)



# 7. FUNCIÓN CONECTADA AL BOTÓN (CON TUS ENLACES DE VARIABLES CORRECTOS)
# sirve para conectar los calculos realizados con el apartado gráfico
def analizar_texto_usuario():
    # 1. Capturar el texto ingresado en el cuadro gráfico de Tkinter
    texto = caja_texto.get("1.0", tk.END).strip()
    if not texto or texto == "Escribe o pega aquí tu texto...":
        messagebox.showwarning("Atención", "Por favor, introduce algún texto para analizar.")
        return
        
    # 2. Limpieza y Lemmatización dinámica
    texto_usuario_limpio = texto.replace(".", "").replace(",", "").lower().split()
    raices_texto_usuario = [stemmer.stem(i) for i in texto_usuario_limpio if len(i) > 3 and i not in palabras_vacias]
    
    if not raices_texto_usuario:
        lbl_veredicto.config(text="TEXTO DEMASIADO CORTO O SIN PALABRAS CLAVE", fg="#ff4d4d")
        return
        
    # 3. Calcular frecuencias (TF) del texto del usuario
    frecuencias_tf_usuario = {}
    for i in set(raices_texto_usuario):
        frecuencias_tf_usuario[i] = raices_texto_usuario.count(i) / len(raices_texto_usuario)
        
    # 4. Generar Vector TF-IDF del usuario
    vector_tf_idf_usuario = []
    for palabra in lista_vocabulario:
        tf_u = frecuencias_tf_usuario.get(palabra, 0)
        idf_u = valores_idf.get(palabra, 0)          
        vector_tf_idf_usuario.append(tf_u * idf_u)
        
    # 5. Comparar similitud contra tus 12 vectores semilla originales
    sim_prog1 = calcular_similitud_coseno(vector_tf_idf_usuario, v_prog1)
    sim_prog2 = calcular_similitud_coseno(vector_tf_idf_usuario, v_prog2)
    sim_prog3 = calcular_similitud_coseno(vector_tf_idf_usuario, v_prog3)

    sim_coch1 = calcular_similitud_coseno(vector_tf_idf_usuario, v_coch1)
    sim_coch2 = calcular_similitud_coseno(vector_tf_idf_usuario, v_coch2)
    sim_coch3 = calcular_similitud_coseno(vector_tf_idf_usuario, v_coch3)

    sim_ajed1 = calcular_similitud_coseno(vector_tf_idf_usuario, v_ajed1)
    sim_ajed2 = calcular_similitud_coseno(vector_tf_idf_usuario, v_ajed2)
    sim_ajed3 = calcular_similitud_coseno(vector_tf_idf_usuario, v_ajed3)

    sim_musi1 = calcular_similitud_coseno(vector_tf_idf_usuario, v_musi1)
    sim_musi2 = calcular_similitud_coseno(vector_tf_idf_usuario, v_musi2)
    sim_musi3 = calcular_similitud_coseno(vector_tf_idf_usuario, v_musi3)

    # Buscar máximos locales por tópico
    max_programacion = max(sim_prog1, sim_prog2, sim_prog3)
    max_coches = max(sim_coch1, sim_coch2, sim_coch3)
    max_ajedrez = max(sim_ajed1, sim_ajed2, sim_ajed3)
    max_musica = max(sim_musi1, sim_musi2, sim_musi3)

    # 6. Actualizar las barras gráficas y sus etiquetas porcentuales (.set multiplica por 100)
    p_prog.set(max_programacion * 100)
    p_coch.set(max_coches * 100)
    p_ajed.set(max_ajedrez * 100)
    p_musi.set(max_musica * 100)
    
    lbl_val_prog.config(text=f"{max_programacion*100:.2f}%")
    lbl_val_coch.config(text=f"{max_coches*100:.2f}%")
    lbl_val_ajed.config(text=f"{max_ajedrez*100:.2f}%")
    lbl_val_musi.config(text=f"{max_musica*100:.2f}%")
    
    # 7. Evaluar ganador absoluto
    max_absoluto = max(max_programacion, max_coches, max_ajedrez, max_musica)
    
    if max_absoluto < 0.10: 
        lbl_veredicto.config(text="TÓPICO NO IDENTIFICADO CLARAMENTE", fg="#ff4d4d")
    else:
        if max_absoluto == max_programacion:
            lbl_veredicto.config(text="TÓPICO DETECTADO: PROGRAMACIÓN 💻", fg="#00ff66")
        elif max_absoluto == max_coches:
            lbl_veredicto.config(text="TÓPICO DETECTADO: COCHES 🚗", fg="#00ffff")
        elif max_absoluto == max_ajedrez:
            lbl_veredicto.config(text="TÓPICO DETECTADO: AJEDREZ ♟️", fg="#ffcc00")
        else:
            lbl_veredicto.config(text="TÓPICO DETECTADO: MÚSICA 🎵", fg="#ff007f")



